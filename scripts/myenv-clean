#!/bin/bash
# myenv-clean - 一键清理 guoda 跑的容器和资源
# 安装位置: /usr/local/bin/myenv-clean
#
# 清理范围(只动你自己的资源,不影响别人):
#   - 名字以 guoda- 开头的 docker 容器
#   - dangling 镜像
#   - 已退出超过 7 天的镜像
#   - (可选)未使用的 docker volume
#
# 不动的东西:
#   - ~/models/(HuggingFace 缓存,下载太贵)
#   - ~/projects/ ~/data/(代码和数据)
#   - 别人跑的容器(无 guoda- 前缀)
#   - ~/logs/(服务日志,可能还要看)

set -uo pipefail

# 颜色
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

PREFIX="${MYENV_PREFIX:-guoda}"

echo -e "${CYAN}🧹 myenv-clean 开始清理(prefix=${PREFIX})${NC}"
echo ""

# === 1. 停掉所有 guoda-* 容器 ===
CONTAINERS=$(docker ps -a --filter "name=${PREFIX}-" --format "{{.Names}}" 2>/dev/null)
if [ -n "$CONTAINERS" ]; then
    echo -e "${YELLOW}📦 停掉以下容器:${NC}"
    echo "$CONTAINERS" | sed 's/^/  - /'
    echo -e "${YELLOW}   继续吗? [y/N]${NC} \c"
    read confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        echo "$CONTAINERS" | xargs -r docker rm -f 2>&1 | sed 's/^/  /'
        echo -e "${GREEN}  ✓ 容器已清理${NC}"
    else
        echo -e "${CYAN}  ℹ 跳过容器清理${NC}"
    fi
else
    echo -e "${GREEN}✓ 没有 ${PREFIX}-* 容器在跑${NC}"
fi
echo ""

# === 2. dangling 镜像(<none>:<none>)===
DANGLING=$(docker images --filter "dangling=true" --format "{{.Repository}}:{{.Tag}} ({{.Size}})" 2>/dev/null)
if [ -n "$DANGLING" ]; then
    echo -e "${YELLOW}🖼 清理 dangling 镜像(<none>):${NC}"
    docker image prune -f 2>&1 | tail -3 | sed 's/^/  /'
else
    echo -e "${GREEN}✓ 没有 dangling 镜像${NC}"
fi
echo ""

# === 3. 一周前的镜像(可选)===
OLD_IMAGES=$(docker images --filter "until=168h" --format "{{.Repository}}:{{.Tag}}" 2>/dev/null | grep -v "<none>" | head -5)
if [ -n "$OLD_IMAGES" ]; then
    echo -e "${YELLOW}🖼 发现 7 天前的镜像:${NC}"
    echo "$OLD_IMAGES" | sed 's/^/  - /'
    echo -e "${YELLOW}   清理它们?(不会动正在使用的) [y/N]${NC} \c"
    read confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        docker image prune -a --filter "until=168h" -f 2>&1 | tail -3 | sed 's/^/  /'
        echo -e "${GREEN}  ✓ 旧镜像已清理${NC}"
    else
        echo -e "${CYAN}  ℹ 跳过旧镜像清理${NC}"
    fi
fi
echo ""

# === 4. 未使用的 volume(谨慎)===
UNUSED_VOLS=$(docker volume ls --filter "dangling=true" --format "{{.Name}}" 2>/dev/null)
if [ -n "$UNUSED_VOLS" ]; then
    echo -e "${RED}⚠ 发现未使用的 docker volume:${NC}"
    echo "$UNUSED_VOLS" | head -10 | sed 's/^/  - /'
    VCOUNT=$(echo "$UNUSED_VOLS" | wc -l)
    [ "$VCOUNT" -gt 10 ] && echo "  ... (共 ${VCOUNT} 个)"
    echo -e "${RED}   ⚠ 清理 volume 会删除数据!是否清理? [y/N]${NC} \c"
    read confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        docker volume prune -f 2>&1 | tail -3 | sed 's/^/  /'
        echo -e "${GREEN}  ✓ volume 已清理${NC}"
    else
        echo -e "${CYAN}  ℹ 跳过 volume 清理${NC}"
    fi
else
    echo -e "${GREEN}✓ 没有未使用的 volume${NC}"
fi
echo ""

# === 5. builder cache(可选)===
echo -e "${YELLOW}🏗 清理 docker builder cache?(释放可能很大) [y/N]${NC} \c"
read confirm
if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
    docker builder prune -f 2>&1 | tail -3 | sed 's/^/  /'
    echo -e "${GREEN}  ✓ builder cache 已清理${NC}"
fi
echo ""

# === 汇总 ===
echo -e "${CYAN}📊 当前 Docker 占用:${NC}"
docker system df
echo ""
echo -e "${GREEN}✓ 清理完成${NC}"
